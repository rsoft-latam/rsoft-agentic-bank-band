# ── Band platform ────────────────────────────────────────────────
# Your Band user API key from https://app.band.ai (developer settings).
BAND_API_KEY=band_u_xxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM for the agents ───────────────────────────────────────────
# Any OpenAI-compatible key. Each agent runs a LangGraph ReAct loop on this model.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
COMMITTEE_LLM_MODEL=gpt-4o

# ── RSoft Agentic Bank backend (the lending logic) ───────────────
# REST base URL of the bank backend the agents call as tools.
BANK_API_URL=http://localhost:8000/api/v1
BANK_BACKEND_API_KEY=bank_dev_xxxxxxxxxxxxxxxxxxxx

# ── Demo borrower ────────────────────────────────────────────────
# CDP wallet the BorrowerClient1 agent represents (Base Sepolia).
CLIENT1_WALLET=0xYourBorrowerWalletAddress

# Created automatically by setup/provision.py:
# DEMO_ROOM_ID=...
